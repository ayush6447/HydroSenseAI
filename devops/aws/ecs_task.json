{
  "family": "hydroponic-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [{
    "name": "backend",
    "image": "your-ecr/hydroponic-backend:latest",
    "portMappings": [{"containerPort": 8000, "protocol": "tcp"}]
  }]
}
